# Copy to .env and fill in. Never commit the real key.
ANTHROPIC_API_KEY=sk-ant-...

# Skimlinks publisher ID — enables affiliate revenue on /api/go outbound links.
# Find it in your Skimlinks dashboard (Account -> Publisher ID, e.g. 123456X1650000).
# If unset, /api/go redirects straight through (links still work, no commission).
SKIMLINKS_ID=

# Optional overrides:
# MIQ_MODEL=claude-haiku-4-5           # cheaper for high-volume review summarization
# PORT=8787
# MIQ_ALLOWED_ORIGINS=https://www.uniqlo.com,https://www2.hm.com,https://www.amazon.com
